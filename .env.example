# Comic Universe Environment Configuration
# Copy this file to .env and update with your settings
# DO NOT COMMIT .env to version control!

# ========== ENVIRONMENT ==========
# Options: development, staging, production
ENVIRONMENT=development

# ========== DATABASE ==========
# Options: sqlite, mysql
DB_TYPE=sqlite

# SQLite (for development)
DB_PATH=./database.sqlite

# MySQL (for production)
DB_HOST=localhost
DB_NAME=comic_universe
DB_USER=root
DB_PASS=
DB_PORT=3306
DB_CHARSET=utf8mb4

# ========== APPLICATION ==========
APP_NAME=Comic Universe
APP_VERSION=1.0.0
SITE_URL=http://localhost:8000/

# ========== DEBUG & LOGGING ==========
DEBUG_MODE=true
LOG_ERRORS=true
LOG_PATH=./logs/

# ========== SESSION ==========
SESSION_TIMEOUT=3600

# ========== API ==========
ENABLE_CORS=false
ALLOWED_ORIGINS=localhost:8000
RATE_LIMIT=60

# ========== UPLOAD ==========
UPLOAD_DIR=./uploads/
MAX_UPLOAD_SIZE=5242880
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,webp

# ========== EMAIL (optional) ==========
MAIL_FROM=noreply@comicuniverse.com
MAIL_FROM_NAME=Comic Universe Store
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ========== CACHE ==========
ENABLE_CACHE=false
CACHE_DIR=./cache/
CACHE_TTL=3600

# ========== SECURITY ==========
# Generate with: bin/generate_secret.php
APP_SECRET=change-this-to-random-string-in-production
